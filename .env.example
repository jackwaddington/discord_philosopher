# Discord Bot Configuration
# Copy this file to .env and add your actual bot token

# Get your Discord bot token from:
# https://discord.com/developers/applications
# 1. Create a new application
# 2. Go to Bot tab
# 3. Copy the token
# 4. Paste it below (replace the text after the =)

DISCORD_TOKEN=your_discord_bot_token_here

# Persona bot tokens (one Discord app/bot per persona)
DISCORD_TOKEN_DON=your_don_token_here
DISCORD_TOKEN_TECHBRO=your_alex_token_here
DISCORD_TOKEN_RAY=your_ray_token_here
DISCORD_TOKEN_PRIYA=your_priya_token_here
DISCORD_TOKEN_SAM=your_sam_token_here

# Disabled personas (create Discord apps if/when enabling)
# DISCORD_TOKEN_KAREN=your_karen_token_here
# DISCORD_TOKEN_ZARA=your_zara_token_here
